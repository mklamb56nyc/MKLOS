  "build_permit_sequence": [
    {
      "step": 1,
      "action": "Confirm build-ready",
      "agency": "Teton County Planning",
      "phone": "208-354-2593 / 208-776-8240",
      "detail": "Verify Required Improvements complete (Certificate of Subdivision Completion issued) AND sanitary restrictions lifted on plat. DA lets County withhold building permits until improvements accepted."
    },
    {
      "step": 2,
      "action": "Soil test holes + site evaluation",
      "agency": "EIPH",
      "detail": "Test holes show 6-8ft soil depth at drainfield + replacement area, EIPH EHS present. CRITICAL PATH - lowland ground + shallow water table (5-38ft) may force mound/pressure system."
    },
    {
      "step": 3,
      "action": "Septic permit",
      "agency": "EIPH",
      "detail": "Septic Permit Application + legal desc + scaled plot plan (primary + replacement drainfield) + floor plans + fee. Tank=2x daily flow; drainfield 63 gal/person/day (IDAPA 58.01.03 + DEQ TGM). Inspect before covering."
    },
    {
      "step": 4,
      "action": "Well",
      "agency": "IDWR + licensed driller",
      "detail": "Single-family domestic well exempt from water-right permit; licensed driller files Well Driller's Report. Shallow local water."
    },
    {
      "step": 5,
      "action": "GEC permit + Building Permit",
      "agency": "Teton County Building Dept",
      "detail": "Engineer-stamped plans (Idaho structural engineer; height grade-to-ridge); site plan showing structures+driveway+well+septic+measurements to property lines (SAME plan for GEC/building/septic); proof of ownership (deed); driveway/approach permit."
    },
    {
      "step": 6,
      "action": "Zoning + wetland/wildlife review",
      "agency": "Teton County Planning",
      "detail": "LA-35 setbacks 30/30/40, 30ft height, wetland setback; NRO/A-WHA determination (avoid via envelope >=100ft from wetland)."
    },
    {
      "step": 7,
      "action": "State + fire inspections -> CO",
      "agency": "Idaho Div of Building Safety + EIPH + Fire District",
      "detail": "Final electrical & plumbing inspections; EIPH final septic approval before Certificate of Occupancy; post address per Title 13; Fire District sign-off (WUI)."
    },
    {
      "step": 8,
      "action": "CC&R architectural review",
      "agency": "Private (subdivision architectural committee if any)",
      "detail": "Separate from and potentially stricter than county code."
    }
  ],
